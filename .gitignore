venv/
.env
.llm_snapshot/
__pycache__/
*.pyc
.askr_log

# machine-specific hook config - each developer runs askr init to generate their own
.claude/settings.json
.claude/settings.local.json

# askr
.askr_history

# generated per-session — regenerated locally, never synced via git to avoid conflicts
askr_state/architecture.md
askr_state/project_brief.md
askr_state/current_task_*.md

# flock sidecar lock files — ephemeral, never committed
askr_state/**/*.lock
askr_state/*.lock

# active session registry — ephemeral, machine-local
askr_state/sessions/

# local notification queue — ephemeral, machine-local, regenerated constantly
askr_state/notifications.log

# contains plaintext secrets (Discord webhook) — never committed
askr_state/config.json

# per-session scratch handovers — staging for the next checkpoint's smart
# merge, never canonical state; deleted by the session itself after its own
# checkpoint, or swept once stale by cleanup_stale_scratches
askr_state/*.scratch.json
