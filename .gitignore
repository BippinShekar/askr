venv/
.env
.llm_snapshot/
__pycache__/
*.pyc
.askr_log

# machine-specific hook config - each developer runs askr init to generate their own
.claude/settings.json
.claude/settings.local.json

# askr
.askr_history

# generated per-session — regenerated locally, never synced via git to avoid conflicts
askr_state/architecture.md
askr_state/project_brief.md
askr_state/current_task_*.md

# flock sidecar lock files — ephemeral, never committed
askr_state/**/*.lock
askr_state/*.lock

# active session registry — ephemeral, machine-local
askr_state/sessions/

# contains plaintext secrets (Discord webhook) — never committed
askr_state/config.json
